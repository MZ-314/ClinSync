ENVIRONMENT=development
SECRET_KEY=your-generated-secret-key-here

POSTGRES_USER=clinsync
POSTGRES_PASSWORD=clinsync_secret
POSTGRES_DB=clinsync_db

# Local docker-compose:
DATABASE_URL=postgresql+asyncpg://clinsync:clinsync_secret@postgres:5432/clinsync_db

# NeonDB (production) — use the POOLED connection string (host contains "-pooler")
# and force SSL via ?ssl=require (asyncpg ignores ?sslmode=require).
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/DBNAME?ssl=require

# CORS origins (must be JSON list). Set to your deployed frontend URL on Render.
# CORS_ORIGINS=["https://your-frontend.onrender.com"]

# FHIR server URL (override on Render — local docker default won't work in prod)
# HAPI_FHIR_URL=https://hapi.fhir.org/baseR4

# Kafka — keep enabled locally (docker-compose). Set to false on Render
# (no broker available). When false, the pipeline runs in-process via
# FastAPI BackgroundTasks after the upload endpoint finishes transcription.
# USE_KAFKA=true

# Audio uploads (Render filesystem is ephemeral — set if mounting a disk or use S3 later)
# AUDIO_UPLOAD_DIR=/tmp/clinsync_audio

GROQ_API_KEY=gsk_...
LLM_MODEL=llama-3.3-70b-versatile

DEEPGRAM_API_KEY=...

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_sk_...
LANGCHAIN_PROJECT=clinsync